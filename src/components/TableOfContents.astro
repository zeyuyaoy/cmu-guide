---
import { HamburgerMenu } from "svelte-radix";

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<aside
	class="w-full lg:w-64 lg:fixed lg:right-0 lg:top-28 h-auto text-sm lg:px-4"
	aria-label="On this page"
	data-toc
>
	<div class="bg-white/0 dark:bg-transparent">
		<div class="flex items-center gap-2 mb-3">
			<HamburgerMenu class="w-4 h-4 text-zinc-500 dark:text-zinc-400" />
			<p class="text-zinc-500 dark:text-zinc-400">On this page</p>
		</div>

		<ul class="pl-4">
			{
				filteredHeadings.map((h) => (
					<li>
						<a
							href={`#${h.slug}`}
							data-toc-link
							data-slug={h.slug}
							class={`block text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors border-l border-zinc-200 dark:border-zinc-700 -ml-4 py-1 ${h.depth === 3 ? "pl-8" : "pl-4"}`}
						>
							{h.text}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</aside>

<script>
	function initTOC() {
		const tocElements = document.querySelectorAll("[data-toc]");

		tocElements.forEach((tocElement) => {
			const links = tocElement.querySelectorAll("[data-toc-link]");
			if (!links.length) return;

			let userClicked = false;
			let clickTimeout: ReturnType<typeof setTimeout> | null = null;

			function setActiveLink(slug: string) {
				links.forEach((link) => {
					link.classList.remove(
						"!text-zinc-900",
						"dark:!text-zinc-100",
						"font-medium",
						"!border-l-zinc-900",
						"dark:!border-l-zinc-100",
					);
				});

				const tocLink = tocElement.querySelector(
					`[data-toc-link][data-slug="${slug}"]`,
				);

				if (tocLink) {
					tocLink.classList.add(
						"!text-zinc-900",
						"dark:!text-zinc-100",
						"font-medium",
						"!border-l-zinc-900",
						"dark:!border-l-zinc-100",
					);
				}
			}

			// Handle clicks on TOC links
			links.forEach((link) => {
				link.addEventListener("click", () => {
					const slug = link.getAttribute("data-slug");
					if (slug) {
						userClicked = true;
						setActiveLink(slug);

						if (clickTimeout) {
							clearTimeout(clickTimeout);
						}

						// Re-enable intersection observer after scroll settles
						clickTimeout = setTimeout(() => {
							userClicked = false;
						}, 1000);
					}
				});
			});

			const observer = new IntersectionObserver(
				(entries) => {
					// Don't update based on scroll if user just clicked
					if (userClicked) return;

					entries.forEach((entry) => {
						const id = entry.target.getAttribute("id");
						if (entry.isIntersecting && id) {
							setActiveLink(id);
						}
					});
				},
				{
					rootMargin: "-100px 0px -66%",
					threshold: 1,
				},
			);

			// Observe all headings
			const headings = document.querySelectorAll("h2[id], h3[id]");
			headings.forEach((heading) => observer.observe(heading));
		});
	}

	// Re-initialize after Astro page transitions
	function initDormTOC() {
		const dorms = (window as any).__dorms__;
		if (!dorms?.length) return;

		const allTocs = document.querySelectorAll("[data-toc] ul");

		allTocs.forEach((toc: Element) => {
			toc.querySelectorAll("[data-dorm-link]").forEach((el) =>
				el.remove(),
			);

			dorms.forEach((dorm: any) => {
				const id = dorm.name.replace(/\s+/g, "-");
				const li = document.createElement("li");
				const a = document.createElement("a");
				a.href = `#${id}`;
				a.setAttribute("data-toc-link", "");
				a.setAttribute("data-slug", id);
				a.setAttribute("data-dorm-link", "");
				a.textContent = dorm.name;
				a.style.cssText =
					"display: block; padding: 4px 0 4px 32px; color: #71717a; text-decoration: none; border-left: 1px solid #e4e4e7; margin-left: -16px; font-size: 0.875rem;";
				a.addEventListener(
					"mouseenter",
					() => (a.style.color = "#18181b"),
				);
				a.addEventListener(
					"mouseleave",
					() => (a.style.color = "#71717a"),
				);
				li.appendChild(a);
				toc.appendChild(li);
			});
		});

		requestAnimationFrame(() => {
			const tocElements = document.querySelectorAll("[data-toc]");
			tocElements.forEach((tocElement) => {
				const links = tocElement.querySelectorAll("[data-toc-link]");
				if (!links.length) return;

				// Track which dorm anchors are currently visible
				const visibleIds = new Set<string>();

				function clearDormLinks() {
					links.forEach((link) => {
						if (link.hasAttribute("data-dorm-link")) {
							link.classList.remove(
								"!text-zinc-900",
								"dark:!text-zinc-100",
								"font-medium",
								"!border-l-zinc-900",
								"dark:!border-l-zinc-100",
							);
						}
					});
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							const id = entry.target.getAttribute("id");
							if (!id) return;

							if (entry.isIntersecting) {
								visibleIds.add(id);
							} else {
								visibleIds.delete(id);
							}
						});

						// Clear all dorm links first, then highlight the last visible one
						clearDormLinks();

						if (visibleIds.size > 0) {
							const lastVisibleId = [...visibleIds].at(-1);
							const tocLink = tocElement.querySelector(
								`[data-toc-link][data-slug="${lastVisibleId}"]`,
							);
							if (tocLink) {
								tocLink.classList.add(
									"!text-zinc-900",
									"dark:!text-zinc-100",
									"font-medium",
									"!border-l-zinc-900",
									"dark:!border-l-zinc-100",
								);
							}
						}
					},
					{
						rootMargin: "-100px 0px -66%",
						threshold: 0,
					},
				);

				document
					.querySelectorAll("[data-dorm-anchor]")
					.forEach((el) => {
						observer.observe(el);
					});
			});
		});
	}

	initTOC();
	initDormTOC();

	window.addEventListener("dorms-ready", initDormTOC);
	document.addEventListener("astro:after-swap", initTOC);
	document.addEventListener("astro:after-swap", initDormTOC);
</script>
