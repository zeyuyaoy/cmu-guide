---
import { GithubLogo } from "svelte-radix";
import { execSync } from "node:child_process";

import Navbar from "@/components/Navbar.astro";
import Sidebar from "@/components/Sidebar.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import PrevNext from "@/components/PrevNext.astro";
import "@/styles/global.css";

const { frontmatter, headings, Content } = Astro.props;

const title = frontmatter.title as string | undefined;
const description = frontmatter.description as string | undefined;
const contributorValues = Array.isArray(frontmatter.contributors)
	? (frontmatter.contributors as unknown[])
	: [];
const contributors = [
	...new Set(
		contributorValues
			.filter((contributor): contributor is string =>
				typeof contributor === "string",
			)
			.map((contributor) => contributor.trim())
			.filter(Boolean),
	),
];
const defaultTitle = "cmu.guide";
const resolvedTitle = title?.trim() || defaultTitle;
const resolvedDescription = description?.trim();

let currentPath = Astro.url.pathname;
if (currentPath !== "/" && currentPath.endsWith("/")) {
	currentPath = currentPath.slice(0, -1);
}

const deploymentUrl = [
	import.meta.env.PUBLIC_SITE_URL,
	import.meta.env.VERCEL_URL,
	import.meta.env.VERCEL_PROJECT_PRODUCTION_URL,
	import.meta.env.URL,
].find((url): url is string => typeof url === "string" && url.trim().length > 0);

const publicBaseUrl = deploymentUrl
	? new URL(deploymentUrl.startsWith("http") ? deploymentUrl : `https://${deploymentUrl}`)
	: Astro.site
		? new URL(Astro.site)
		: new URL(Astro.url.origin);
publicBaseUrl.pathname = "/";
publicBaseUrl.search = "";
publicBaseUrl.hash = "";

const pageUrl = new URL(currentPath, publicBaseUrl).toString();

const frontmatterImage = frontmatter.image as
	| string
	| { src?: string }
	| undefined;
const imageSource =
	typeof frontmatterImage === "string"
		? frontmatterImage
		: frontmatterImage?.src;
const generatedSocialImage = `/og${currentPath === "/" ? "/index" : currentPath}.png`;
const socialImageUrl = new URL(imageSource || generatedSocialImage, publicBaseUrl).toString();

const hideTableOfContents = Boolean(frontmatter.hideTableOfContents);
const hidePrevNext = Boolean(frontmatter.hidePrevNext);
const hidePageMeta = Boolean(frontmatter.hidePageMeta);
const hideHeader = Boolean(frontmatter.hideHeader);
const hideTitle = hideHeader || Boolean(frontmatter.hideTitle);
const hideDescription = hideHeader || Boolean(frontmatter.hideDescription);
const contentMaxWidthClass =
	(frontmatter.contentMaxWidth as string) || "max-w-4xl";
const pageSpacingClass = (frontmatter.pageSpacing as string) || "py-16";
const contentBodyClass =
	(frontmatter.contentBodyClass as string) ||
	"prose prose-zinc prose-a:text-blue-600 dark:prose-a:text-blue-400 dark:prose-invert lg:prose-base";

const ogType = currentPath === "/" ? "website" : "article";
const twitterCard = "summary_large_image";

let filePath = currentPath === "/" ? "index" : currentPath.slice(1);

let ext = "mdx";
try {
	execSync(`test -f src/pages/${filePath}.mdx`);
} catch {
	ext = "md";
}

filePath = `${filePath}.${ext}`;
const githubEditUrl = `https://github.com/ScottyLabs/cmu-guide/edit/main/src/pages/${filePath}`;

// Get Git metadata
let lastEdited: string | null = null;
let lastCommitUrl: string | null = null;

try {
	const filePathFull = `src/pages/${filePath}`;

	// Get last commit hash
	const hash = execSync(`git log -1 --format=%H -- "${filePathFull}"`, {
		encoding: "utf-8",
	}).trim();

	if (hash) {
		lastCommitUrl = `https://github.com/ScottyLabs/cmu-guide/commit/${hash}`;

		// Get last commit date
		const date = execSync(
			`git log -1 --format=%cd --date=short -- "${filePathFull}"`,
			{ encoding: "utf-8" },
		).trim();

		if (date) {
			lastEdited = new Date(date).toLocaleDateString("en-US", {
				year: "numeric",
				month: "long",
				day: "numeric",
			});
		}
	}
} catch (e) {
	// Git info not available (e.g., in dev mode or file not committed)
	console.warn(`Could not fetch Git info for ${filePath}`, e);
}

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

const headingList = headings as Heading[];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<link
			rel="apple-touch-icon"
			sizes="57x57"
			href="/apple-icon-57x57.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="60x60"
			href="/apple-icon-60x60.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="72x72"
			href="/apple-icon-72x72.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="76x76"
			href="/apple-icon-76x76.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="114x114"
			href="/apple-icon-114x114.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="120x120"
			href="/apple-icon-120x120.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="144x144"
			href="/apple-icon-144x144.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="152x152"
			href="/apple-icon-152x152.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-icon-180x180.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="192x192"
			href="/android-icon-192x192.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="96x96"
			href="/favicon-96x96.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link rel="manifest" href="/manifest.json" />
		<meta name="msapplication-TileColor" content="#ffffff" />
		<meta name="msapplication-TileImage" content="/ms-icon-144x144.png" />
		<meta name="theme-color" content="#ffffff" />
		{resolvedDescription && <meta name="description" content={resolvedDescription} />}
		<link rel="canonical" href={pageUrl} />

		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:title" content={resolvedTitle} />
		{resolvedDescription && (
			<meta property="og:description" content={resolvedDescription} />
		)}
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:url" content={pageUrl} />
		<meta name="twitter:title" content={resolvedTitle} />
		{resolvedDescription && (
			<meta name="twitter:description" content={resolvedDescription} />
		)}
		<meta name="twitter:image" content={socialImageUrl} />

		<title>{resolvedTitle}</title>

		<script is:inline define:vars={{ pagefindEnabled: import.meta.env.PROD }}>
			if (pagefindEnabled) {
				window.addEventListener("DOMContentLoaded", async () => {
					const pagefindPath = ["/pagefind", "pagefind.js"].join("/");

					try {
						window.pagefind = await import(pagefindPath);
						await window.pagefind.init();
					} catch (error) {
						console.error("Failed to load the generated Pagefind index.", error);
					}
				});
			}
		</script>

		<script is:inline>
			if (
				localStorage.theme === "dark" ||
				(!("theme" in localStorage) &&
					window.matchMedia("(prefers-color-scheme: dark)").matches)
			) {
				document.documentElement.classList.add("dark");
			}
		</script>
	</head>

	<body class="bg-white dark:bg-zinc-900 min-h-screen">
		<Navbar />
		<Sidebar />

		<!-- Main content area -->
		<div class={`pt-16 md:pl-64 ${hideTableOfContents ? "" : "lg:pr-64"}`}>
			<div
				class={`${contentMaxWidthClass} w-full mx-auto px-4 sm:px-6 lg:px-8`}
			>
				<main class={pageSpacingClass}>
					{
						!hideTitle && title && (
							<h1 class="text-4xl lg:text-5xl font-bold text-zinc-900 dark:text-zinc-100 mb-4">
								{title}
							</h1>
						)
					}
					{
						!hideDescription && resolvedDescription && (
							<p class="text-xl lg:text-2xl text-zinc-600 dark:text-zinc-400 mb-6 break-words">
								{resolvedDescription}
							</p>
						)
					}

					{
						!hidePageMeta && (
							<>
								<a
									href={githubEditUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full border border-zinc-200 dark:border-zinc-700 text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors no-underline"
								>
									<GithubLogo class="size-4" />
									Edit page on GitHub
								</a>

								{(lastEdited || contributors.length > 0) && (
									<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-zinc-600 dark:text-zinc-400 mt-4 pb-6 mb-8 border-b border-zinc-200 dark:border-zinc-700">
										{lastEdited && lastCommitUrl && (
											<div class="flex items-center gap-1.5">
												<span class="text-zinc-500 dark:text-zinc-500">
													Last edited:
												</span>
												<a
													href={lastCommitUrl}
													target="_blank"
													rel="noopener noreferrer"
													class="text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 underline decoration-zinc-300 dark:decoration-zinc-600 underline-offset-2 transition-colors"
												>
													{lastEdited}
												</a>
											</div>
										)}
										{contributors.length > 0 && (
											<div class="flex items-center gap-1.5 flex-wrap">
												<span class="text-zinc-500 dark:text-zinc-500">
													Contributors:
												</span>
												<span class="text-zinc-700 dark:text-zinc-300">
													{contributors.join(", ")}
												</span>
											</div>
										)}
									</div>
								)}
							</>
						)
					}

					{
						!hideTableOfContents && (
							<div class="lg:hidden mb-8">
								<TableOfContents headings={headingList} />
							</div>
						)
					}

					<article data-pagefind-body class={contentBodyClass}>
						{Content ? <Content /> : <slot />}
					</article>

					{!hidePrevNext && <PrevNext />}
				</main>
			</div>

			{
				!hideTableOfContents && (
					<div class="hidden lg:block" style="overflow: visible;">
						<TableOfContents headings={headingList} />
					</div>
				)
			}
		</div>
	</body>
</html>
